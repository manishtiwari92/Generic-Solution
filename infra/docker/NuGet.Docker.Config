<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGet configuration used ONLY inside Docker builds.
  Clears all Windows-specific fallback package folders so the Linux container
  does not try to resolve packages from paths like
  "C:\Program Files (x86)\Microsoft Visual Studio\Shared\NuGetPackages".
-->
<configuration>
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>
</configuration>
