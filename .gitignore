# Visual Studio
# -------------------------------------------------------
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser
Generated\ Files/
ScaffoldingReadMe.txt
MigrationBackup/
.localhistory/
*.binlog

# -------------------------------------------------------
# Visual Studio Code
# -------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# -------------------------------------------------------
# JetBrains Rider
# -------------------------------------------------------
.idea/
*.sln.iml
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# -------------------------------------------------------
