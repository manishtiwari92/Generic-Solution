# -------------------------------------------------------
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
TestResult.xml
nunit-*.xml
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml
BenchmarkDotNet.Artifacts/

# -------------------------------------------------------
# Secrets and credentials — NEVER commit
# -------------------------------------------------------
*.pfx
*.p12
*.key
appsettings.*.local.json
secrets.json
.env
.env.*
!.env.example

# -------------------------------------------------------
# AWS / Lambda
# -------------------------------------------------------
# Lambda deployment packages
*.zip
# SAM build output
.aws-sam/

# -------------------------------------------------------
# Docker
# -------------------------------------------------------
# Local Docker override files (contain env-specific config)
docker-compose.override.yml
docker-compose.local.yml

