{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.AmazonCloudWatch" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{CorrelationId}] [{ClientType}] [{JobId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "ConnectionStrings": {
    "Workflow": "/IPS/Common/prod/Database/Workflow"
  },
  "AWS": {
    "Region": "us-east-1"
  },
  "Email": {
    "SmtpPassword": "/IPS/Common/prod/Smtp"
  },
  "ApiKey": {
    "Value": "/IPS/Common/prod/ApiKey"
  }
}
